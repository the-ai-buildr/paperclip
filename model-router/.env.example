# --- Upstream (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter attribution headers:
OPENROUTER_HTTP_REFERER=https://paperclip.ing
OPENROUTER_X_TITLE=Paperclip Model Router

# --- Router auth (optional) ---
# Comma-separated keys clients must send as: Authorization: Bearer <key>
# Leave empty to disable auth (fine for localhost-only).
ROUTER_API_KEYS=

# --- Role behavior ---
ROUTER_DEFAULT_ROLE=fast
ROLES_CONFIG_PATH=roles.yaml
REQUEST_TIMEOUT_SECONDS=600

# --- Per-role overrides (optional; override roles.yaml) ---
# MODEL_ROLE_THINKING=anthropic/claude-opus-4
# MODEL_ROLE_FAST=anthropic/claude-sonnet-4
# MODEL_ROLE_CHEAP=google/gemini-2.0-flash-001
